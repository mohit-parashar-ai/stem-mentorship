{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Codvo project-shared Claude Code settings. Checked into git. Per-developer overrides go in settings.local.json (gitignored).",

  "permissions": {
    "deny": [
      "Bash(git commit *--no-verify*)",
      "Bash(git commit *-n *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git filter-repo*)",
      "Bash(git filter-branch*)",
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(npm install*)",
      "Bash(npm i *)",
      "Bash(yarn add*)",
      "Bash(brew install*)",
      "Bash(pipx install*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo rm*)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/credentials.json)"
    ],
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(npm run test*)",
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(npx tsc*)",
      "Bash(find . -name*)",
      "Bash(grep -r*)",
      "Bash(.claude/hooks/*.sh)",
      "Bash(bash .claude/hooks/*)",
      "Bash(git config core.hooksPath*)"
    ]
  }
}
